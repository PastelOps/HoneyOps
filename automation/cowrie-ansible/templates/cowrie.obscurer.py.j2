def fs_pickle(cowrie_install_dir):
    launch = "bash -c \"source /opt/cowrie/cowrie-env/bin/activate && python3 {0}/../cowrie-env/bin/fsctl {1}/src/cowrie/data/fs.pickle\"".format(cowrie_install_dir, cowrie_install_dir)
    p = pexpect.spawn(launch)
    p.expect(".*.\r\n\r\nfs.pickle:.*")
    p.sendline("rm -r /home/phil")
    p.expect(".*fs.pickle.*")
    for user in users:
        p.sendline("mkdir /home/{0}".format(user))
        p.expect(".*fs.pickle.*")
    p.sendline("exit")


