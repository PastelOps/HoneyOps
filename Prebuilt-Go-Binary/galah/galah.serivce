# Initialization file for Galah for systemd

[Unit]
Description=Galah LLM Web HoneyPot
Wants=network.target
After=network.target

[Service]
Type=simple
User=galah
Group=galah
WorkingDirectory=/opt/galah
ProtectSystem=true
ExecStart=bash /opt/galah/execute_galah.sh
PermissionsStartOnly=yes
Restart=always
StateDirectory=galah
LogsDirectory=galah
StandardOutput=syslog
StandardError=syslog
SyslogIdentifier=galah
AmbientCapabilities=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target

